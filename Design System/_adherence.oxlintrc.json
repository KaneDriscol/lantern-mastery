{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/marketing/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|bronze)$/]",
        "message": "<Badge> variant must be one of 'pill' | 'bronze'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|disabled|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, disabled, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|secondary-on-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'secondary-on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|key|ref|className|style|children)$/]",
        "message": "<CategoryTabs> doesn't accept that prop. Declared props: tabs, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparisonCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|summary|style|key|ref|className|style|children)$/]",
        "message": "<ComparisonCard> doesn't accept that prop. Declared props: name, summary, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CookieConsentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:onAccept|onDismiss|style|key|ref|className|style|children)$/]",
        "message": "<CookieConsentCard> doesn't accept that prop. Declared props: onAccept, onDismiss, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|subline|children|style|key|ref|className|style|children)$/]",
        "message": "<CtaBand> doesn't accept that prop. Declared props: variant, title, subline, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBand'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:bronze|dark)$/]",
        "message": "<CtaBand> variant must be one of 'bronze' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, description, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subhead|children|illustration|dark|style|key|ref|className|style|children)$/]",
        "message": "<HeroBand> doesn't accept that prop. Declared props: title, subhead, children, illustration, dark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PracticeTrackerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:drillName|date|progress|notes|style|key|ref|className|style|children)$/]",
        "message": "<PracticeTrackerCard> doesn't accept that prop. Declared props: drillName, date, progress, notes, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrincipleCalloutCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|ctaLabel|onCta|style|key|ref|className|style|children)$/]",
        "message": "<PrincipleCalloutCard> doesn't accept that prop. Declared props: title, description, ctaLabel, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResourceConnectorTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|description|style|key|ref|className|style|children)$/]",
        "message": "<ResourceConnectorTile> doesn't accept that prop. Declared props: icon, name, description, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceReferenceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:sourceName|author|date|excerpt|style|key|ref|className|style|children)$/]",
        "message": "<SourceReferenceCard> doesn't accept that prop. Declared props: sourceName, author, date, excerpt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TechniqueIllustrationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|steps|style|key|ref|className|style|children)$/]",
        "message": "<TechniqueIllustrationCard> doesn't accept that prop. Declared props: title, steps, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: placeholder, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|children|style|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: href, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:activeLink|onNavigate|onSignIn|onLearnNow|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: activeLink, onNavigate, onSignIn, onLearnNow."
      },
      {
        "selector": "JSXOpeningElement[name.name='VirtueCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|style|key|ref|className|style|children)$/]",
        "message": "<VirtueCard> doesn't accept that prop. Declared props: name, description, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
