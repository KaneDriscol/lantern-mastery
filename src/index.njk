---
layout: base.njk
# The homepage: a short intro, then every note newest-first.
# The list is generated from your posts — you never edit it by hand.
---
<section class="home-intro">
  <div class="container">
    <h1>The Lantern</h1>
    <p>A running notebook of thoughts and lessons in my pursuit of Mastery.</p>
  </div>
</section>

{% if featuredPrinciples.length %}
{% set items = [] %}
{% for p in featuredPrinciples %}
  {% set _ = items.push({ statement: p.statement, tag: p.post.tag, title: p.post.title, url: (p.post.url | url) }) %}
{% endfor %}
<section class="home-principles">
  <div class="container">
    <div class="principle-rotator sc-principle" id="principle-rotator" data-principles='{{ items | dump | safe }}'>
      <span class="sc-principle-label">Principle · <a class="principle-rotator-source" id="principle-rotator-source" href="{{ items[0].url }}">{{ items[0].title }}</a></span>
      <p class="sc-principle-statement" id="principle-rotator-statement">{{ items[0].statement }}</p>
      {% if items.length > 1 %}
      <div class="principle-rotator-dots" id="principle-rotator-dots">
        {% for item in items %}
        <button type="button" class="principle-rotator-dot{% if loop.index0 == 0 %} active{% endif %}" aria-label="Show principle {{ loop.index }}" data-index="{{ loop.index0 }}"></button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>
<script src="{{ '/js/principles.js' | cacheBust | url }}" defer></script>
{% endif %}

<section class="notebook">
  <div class="container">
    <div class="notebook-list">
      {% set posts = collections.post | reverse %}
      {% for post in posts %}
      <a href="{{ post.url | url }}" class="notebook-entry">
        {% if post.data.tag %}<div class="note-tag">{{ post.data.tag }}</div>{% endif %}
        <h2>{{ post.data.title }}</h2>
        {% if post.data.excerpt %}<p class="note-excerpt">{{ post.data.excerpt }}</p>{% endif %}
        <div class="note-date">{{ post.date | readableDate }}{% if post.data.readingTime %} · {{ post.data.readingTime }}{% endif %}</div>
      </a>
      {% else %}
      <p class="notebook-empty">No notes yet. Write your first one with <code>npm run new "My title"</code>, then run <code>npm run serve</code>.</p>
      {% endfor %}
    </div>
  </div>
</section>
